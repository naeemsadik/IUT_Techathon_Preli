HOST=0.0.0.0
PORT=8000
DEBUG=false

# Office hours for off-hours alerts (HH:MM, 24-hour)
OFFICE_START=09:00
OFFICE_END=17:00

# Continuous ON duration before room alert (seconds). Use 20 for demos.
DURATION_THRESHOLD_SECONDS=7200

# Continuous ON duration before per-device alert (seconds).
# Use 0 to fire immediately on every ON device; use a positive value for a real threshold.
DEVICE_DURATION_THRESHOLD_SECONDS=3600

# Periodic alert sweep interval (seconds)
ALERT_SWEEP_INTERVAL_SECONDS=30

# SQLite database path for cold state
# Inside Docker / Coolify, mount a persistent volume here.
SQLITE_PATH=data/office_energy.db

# Comma-separated list of origins allowed to call the API (CORS).
# Defaults to localhost dev hosts when empty. In production set this to your
# Vercel domain(s), e.g.:
#   CORS_ALLOW_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
CORS_ALLOW_ORIGINS=
