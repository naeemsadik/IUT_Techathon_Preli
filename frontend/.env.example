# Frontend environment variables
#
# Copy to .env.local for local development.
# In Vercel, set these under Project Settings → Environment Variables.

# Backend base URL — public in the browser (hence NEXT_PUBLIC_ prefix).
# Local dev: defaults to http://127.0.0.1:8000 if unset.
# Production: e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# WebSocket base URL — must match API scheme: ws:// for http, wss:// for https.
NEXT_PUBLIC_WS_BASE_URL=ws://127.0.0.1:8000